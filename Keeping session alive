package org.example.validation

/**
 * Represents a single validation failure against the audit map.
 *
 * MissingKey       → mandatory key not found in map at all
 * NullOrEmptyValue → key exists but value is null or empty string
 * FormatViolation  → key exists, value non-empty, but quote format is wrong
 *
 * Each failure carries the key and a human-readable reason.
 * Copy this file as-is. Do not modify.
 */
sealed trait ValidationFailure {
  def key: String
  def reason: String
}

object ValidationFailure {

  case class MissingKey(key: String) extends ValidationFailure {
    val reason: String = s"Mandatory key '$key' is missing from the audit map."
  }

  case class NullOrEmptyValue(key: String) extends ValidationFailure {
    val reason: String = s"Key '$key' is present but its value is null or empty."
  }

  case class FormatViolation(key: String, expectedFormat: FormatType, actualValue: String)
      extends ValidationFailure {
    val reason: String = expectedFormat match {
      case FormatType.DOUBLE_QUOTED =>
        s"Key '$key' must have a value wrapped in double quotes (\"). Actual value: [$actualValue]"
      case FormatType.SINGLE_QUOTED =>
        s"Key '$key' must have a value wrapped in single quotes ('). Actual value: [$actualValue]"
      case FormatType.RAW =>
        s"Key '$key' must have a raw value (no quote wrapping). Actual value: [$actualValue]"
    }
  }
}
