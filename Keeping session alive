package org.example.validation

/**
 * Result of validating an audit map against a schema.
 *
 * passed   → true only if zero failures
 * failures → full list of what failed and why (empty if passed)
 *
 * Usage:
 *   val result = AuditMapValidator.validate(auditMap, schema)
 *   if (!result.passed) result.failures.foreach(f => logger.error(f.reason))
 *
 * Copy this file as-is. Do not modify.
 */
case class ValidationResult(
    passed: Boolean,
    failures: List[ValidationFailure]
) {

  /** Convenience: all failure reasons as a single formatted string. */
  def failureSummary: String =
    if (passed) "Validation passed. No failures."
    else failures.map(f => s"  [${f.getClass.getSimpleName}] ${f.reason}").mkString("\n")
}
