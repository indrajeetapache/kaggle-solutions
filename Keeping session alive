val fileSizeBytes = fs.getContentSummary(new Path(filepath)).getLength
val derivedPartitions        = math.ceil(fileSizeBytes.toDouble / (64L * 1024 * 1024)).toInt
val maxMeaningfulPartitions  = math.ceil(fileSizeBytes.toDouble / (10L * 1024 * 1024)).toInt
val totalCores               = spark.sparkContext.defaultParallelism
val numOfOutputPartitions    = math.min(math.max(derivedPartitions, totalCores), maxMeaningfulPartitions)

logger.info(s"""
  fileSizeMB              : ${fileSizeBytes / (1024 * 1024)} MB
  targetPartitionSizeBytes: 64 MB  → derivedPartitions = $derivedPartitions
  minTaskSizeBytes        : 10 MB  → maxMeaningfulPartitions = $maxMeaningfulPartitions
  totalCores              : $totalCores
  ─────────────────────────────────────────
  finalPartitions         : $numOfOutputPartitions
""")
