spark = SparkSession.builder.appName("SQLQuery").getOrCreate()
spark.sparkContext.setLogLevel("ERROR")
result = spark.sql("SELECT count(*) FROM gcgeetlnaenrd_work.UDM_DEPOSIT_INCR_RP")
print(result.collect()[0][0])
