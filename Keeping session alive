package org.example.validation

/**
 * Defines the expected value format for a key in the audit map.
 *
 * DOUBLE_QUOTED  → value must start and end with "  e.g. "169912"
 * SINGLE_QUOTED  → value must start and end with '  e.g. '169912'
 * RAW            → value must NOT be wrapped in any quotes e.g. false, text
 *
 * Copy this file as-is. Do not modify.
 */
sealed trait FormatType

object FormatType {
  case object DOUBLE_QUOTED extends FormatType
  case object SINGLE_QUOTED extends FormatType
  case object RAW           extends FormatType
}
