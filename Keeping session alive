#!/bin/bash
export SPARK_HOME=/opt/cloudera/parcels/SPARK3/lib/spark3
export PATH=$SPARK_HOME/bin:$PATH

result=$(spark-sql --master yarn \
  -e "SELECT count(*) FROM my_database.my_table WHERE dt = '2026-05-05'" | tail -1)

echo "Count: $result"


# create the python query script
cat << 'EOF' > /tmp/run_query.py
